function SearchPage({query:initQ=''}){
  const [query, setQuery] = React.useState(decodeURIComponent(initQ));
  const [results, setResults] = React.useState([]);
  const [loading, setLoading] = React.useState(false);
  const [page, setPage] = React.useState(1);
  const [hasMore, setHasMore] = React.useState(false);
  const [filters, setFilters] = React.useState({type:'',status:'',genre:''});
  const [totalResults, setTotalResults] = React.useState(0);
  const debounceRef = React.useRef(null);

  const doSearch = React.useCallback(async (q, pg, flt, append=false) => {
    if (!q.trim()) { setResults([]); return; }
    setLoading(true);
    let path = `/anime?q=${encodeURIComponent(q)}&limit=20&page=${pg}&sfw=false`;
    if (flt.type) path += `&type=${flt.type}`;
    if (flt.status) path += `&status=${flt.status}`;
    if (flt.genre) path += `&genres=${flt.genre}`;
    const d = await jikan(path);
    if (d?.data) {
      setResults(r => append ? [...r,...d.data] : d.data);
      setHasMore(d.pagination?.has_next_page||false);
      setTotalResults(d.pagination?.items?.total||0);
    }
    setLoading(false);
  },[]);

  React.useEffect(()=>{
    if (initQ) { setQuery(decodeURIComponent(initQ)); doSearch(decodeURIComponent(initQ),1,filters); }
  },[initQ]);

  const handleInputChange = v => {
    setQuery(v);
    clearTimeout(debounceRef.current);
    debounceRef.current = setTimeout(()=>{
      setPage(1); doSearch(v,1,filters);
    }, 500);
  };

  const loadMore = () => {
    const np = page + 1;
    setPage(np);
    doSearch(query, np, filters, true);
  };

  return (
    <div className="max-w-[1400px] mx-auto px-4 md:px-8 pt-24 pb-16">
      {/* Search Header */}
      <div className="mb-8">
        <h1 className="text-3xl font-black gradient-text mb-2">Search Anime</h1>
        <p className="text-gray-500">Explore 50,000+ anime titles</p>
      </div>

      {/* Search Bar */}
      <div className="flex gap-3 mb-6 flex-wrap">
        <div className="flex-1 relative min-w-64">
          <span className="absolute left-4 top-1/2 -translate-y-1/2 text-gray-500">🔍</span>
          <input value={query} onChange={e=>handleInputChange(e.target.value)}
            placeholder="Search any anime…"
            className="input-dark w-full rounded-2xl pl-12 pr-4 py-3.5 text-base"/>
        </div>
        <select value={filters.type} onChange={e=>{const f={...filters,type:e.target.value};setFilters(f);setPage(1);doSearch(query,1,f)}}
          className="input-dark rounded-xl px-4 py-3 text-sm">
          <option value="">All Types</option>
          {['tv','movie','ova','special','ona','music'].map(t=>(
            <option key={t} value={t}>{t.toUpperCase()}</option>
          ))}
        </select>
        <select value={filters.status} onChange={e=>{const f={...filters,status:e.target.value};setFilters(f);setPage(1);doSearch(query,1,f)}}
          className="input-dark rounded-xl px-4 py-3 text-sm">
          <option value="">All Status</option>
          {['airing','complete','upcoming'].map(s=>(
            <option key={s} value={s}>{s.charAt(0).toUpperCase()+s.slice(1)}</option>
          ))}
        </select>
        <select value={filters.genre} onChange={e=>{const f={...filters,genre:e.target.value};setFilters(f);setPage(1);doSearch(query,1,f)}}
          className="input-dark rounded-xl px-4 py-3 text-sm">
          <option value="">All Genres</option>
          {GENRES.map(g=><option key={g.id} value={g.id}>{g.name}</option>)}
        </select>
      </div>

      {totalResults>0 && (
        <p className="text-gray-500 text-sm mb-6">Found <span className="text-neon-purple font-bold">{fmt(totalResults)}</span> results for <span className="text-white">"{query}"</span></p>
      )}

      {!query && !loading && (
        <div>
          <AnimeRow title="Popular Anime" icon="🔥" apiPath="/top/anime?filter=bypopularity&limit=14"/>
          <AnimeRow title="New Releases" icon="🆕" apiPath="/seasons/now&limit=14"/>
        </div>
      )}

      {loading && results.length===0 && <SkeletonGrid/>}

      {results.length>0 && (
        <>
          <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 mb-8">
            {results.map(a=>(
              <div key={a.mal_id} className="flex justify-center">
                <AnimeCard anime={a}/>
              </div>
            ))}
          </div>
          {hasMore && (
            <div className="text-center">
              <button onClick={loadMore} disabled={loading}
                className="btn-primary px-8 py-3 rounded-xl font-semibold disabled:opacity-50">
                {loading ? 'Loading…' : 'Load More'}
              </button>
            </div>
          )}
        </>
      )}

      {!loading && query && results.length===0 && (
        <div className="text-center py-24">
          <div className="text-6xl mb-4">😔</div>
          <h2 className="text-xl font-bold text-white mb-2">No results found</h2>
          <p className="text-gray-500">Try a different search term or adjust your filters</p>
        </div>
      )}
    </div>
  );
}

