<div id="root"></div>
<script type="text/babel">

/* ============================================================
   CONSTANTS & UTILITIES
============================================================ */
const JIKAN = 'https://api.jikan.moe/v4';
let _lastCall = 0;
const sleep = ms => new Promise(r => setTimeout(r, ms));

async function jikan(path) {
  const now = Date.now();
  const delta = now - _lastCall;
  if (delta < 400) await sleep(400 - delta);
  _lastCall = Date.now();
  try {
    const r = await fetch(JIKAN + path);
    if (!r.ok) throw new Error(r.status);
    return r.json();
  } catch(e) { console.warn('Jikan:', e); return null; }
}

const apiCache = {};
async function cachedJikan(path) {
  if (apiCache[path]) return apiCache[path];
  const data = await jikan(path);
  if (data) apiCache[path] = data;
  return data;
}

const GENRES = [
  {id:1,name:'Action',icon:'⚔️',color:'from-red-600 to-orange-500'},
  {id:2,name:'Adventure',icon:'🗺️',color:'from-amber-500 to-yellow-400'},
  {id:4,name:'Comedy',icon:'😂',color:'from-yellow-400 to-lime-400'},
  {id:22,name:'Romance',icon:'💕',color:'from-pink-500 to-rose-400'},
  {id:10,name:'Fantasy',icon:'🧙',color:'from-purple-600 to-violet-400'},
  {id:14,name:'Horror',icon:'👻',color:'from-gray-800 to-gray-600'},
  {id:24,name:'Sci-Fi',icon:'🚀',color:'from-blue-600 to-cyan-400'},
  {id:36,name:'Slice of Life',icon:'☕',color:'from-green-500 to-teal-400'},
  {id:30,name:'Sports',icon:'⚽',color:'from-emerald-500 to-green-400'},
  {id:7,name:'Mystery',icon:'🔍',color:'from-indigo-600 to-blue-500'},
  {id:40,name:'Psychological',icon:'🧠',color:'from-fuchsia-600 to-purple-500'},
  {id:8,name:'Drama',icon:'🎭',color:'from-rose-600 to-pink-500'},
  {id:13,name:'Historical',icon:'🏯',color:'from-stone-600 to-amber-700'},
  {id:19,name:'Music',icon:'🎵',color:'from-cyan-500 to-blue-400'},
  {id:27,name:'Shounen',icon:'⚡',color:'from-orange-500 to-red-400'},
  {id:42,name:'Seinen',icon:'🌑',color:'from-slate-700 to-gray-600'},
];

const STATUS_CONFIG = {
  watching:  {label:'Watching',  color:'badge-watching', icon:'▶️'},
  completed: {label:'Completed', color:'badge-completed', icon:'✅'},
  planToWatch:{label:'Plan to Watch',color:'badge-plan',  icon:'📋'},
  dropped:   {label:'Dropped',   color:'badge-dropped',  icon:'❌'},
};

function fmt(n){return n>=1000?(n/1000).toFixed(1)+'k':String(n||0)}
function hrs(eps){return Math.round((eps||0)*24/60)}
function readLS(k,d){try{const v=localStorage.getItem(k);return v?JSON.parse(v):d}catch{return d}}
function writeLS(k,v){try{localStorage.setItem(k,JSON.stringify(v))}catch{}}
function hashPage(){return window.location.hash.slice(1)||'home'}
function navigate(page){window.location.hash=page;window.scrollTo({top:0,behavior:'smooth'})}

/* ============================================================
   CONTEXT
============================================================ */
const Ctx = React.createContext(null);

function AppProvider({children}){
  const [user,setUser] = React.useState(() => readLS('anivault_user', {
    isLoggedIn:false, username:'', email:'', avatar:'', joinDate:'',
    watchlist:{watching:[],completed:[],planToWatch:[],dropped:[]},
    ratings:{}, favoriteAnime:[]
  }));
  const [toast, setToast] = React.useState(null);

  const saveUser = u => { setUser(u); writeLS('anivault_user', u); };

  const showToast = (message, type='success') => {
    setToast({message, type});
    setTimeout(()=>setToast(null), 3200);
  };

  const getAnimeStatus = id => {
    const u = user;
    if (!u.watchlist) return null;
    for (const s of Object.keys(u.watchlist)){
      if (u.watchlist[s].find(a=>a.mal_id===id)) return s;
    }
    return null;
  };

  const addToList = (anime, status) => {
    const id = anime.mal_id;
    const u = JSON.parse(JSON.stringify(user));
    // Remove from all lists first
    for (const s of Object.keys(u.watchlist)){
      u.watchlist[s] = u.watchlist[s].filter(a=>a.mal_id!==id);
    }
    const entry = {
      mal_id: id,
      title: anime.title,
      title_english: anime.title_english||anime.title,
      poster: anime.images?.jpg?.large_image_url || anime.images?.jpg?.image_url || '',
      episodes: anime.episodes||0,
      score: anime.score||0,
      genres: anime.genres||[],
      year: anime.year||anime.aired?.prop?.from?.year||'?',
      type: anime.type||'TV',
      addedAt: new Date().toISOString(),
      myEpisodes: 0,
    };
    u.watchlist[status].push(entry);
    saveUser(u);
    showToast(`Added "${anime.title}" to ${STATUS_CONFIG[status].label}`, 'success');
  };

  const removeFromList = (id) => {
    const u = JSON.parse(JSON.stringify(user));
    for (const s of Object.keys(u.watchlist)){
      u.watchlist[s] = u.watchlist[s].filter(a=>a.mal_id!==id);
    }
    saveUser(u);
    showToast('Removed from list', 'info');
  };

  const rateAnime = (id, rating) => {
    const u = JSON.parse(JSON.stringify(user));
    u.ratings[id] = rating;
    saveUser(u);
  };

  const login = ({username, email}) => {
    const u = JSON.parse(JSON.stringify(user));
    u.isLoggedIn = true;
    u.username = username;
    u.email = email;
    u.avatar = username[0]?.toUpperCase()||'A';
    u.joinDate = new Date().toISOString();
    saveUser(u);
    showToast(`Welcome back, ${username}! 🎌`, 'success');
  };

  const logout = () => {
    const u = JSON.parse(JSON.stringify(user));
    u.isLoggedIn = false;
    saveUser(u);
    navigate('home');
    showToast('Logged out successfully', 'info');
  };

  const getAllWatched = () => {
    const all = [];
    for (const s of Object.keys(user.watchlist||{})){
      (user.watchlist[s]||[]).forEach(a=>all.push({...a, status:s}));
    }
    return all;
  };

  const getTotalEpisodes = () => getAllWatched().reduce((s,a)=>s+(a.myEpisodes||a.episodes||0),0);
  const getAvgRating = () => {
    const r = Object.values(user.ratings||{});
    return r.length ? (r.reduce((a,b)=>a+b,0)/r.length).toFixed(1) : '—';
  };

  return (
    <Ctx.Provider value={{
      user, saveUser, showToast, getAnimeStatus, addToList, removeFromList,
      rateAnime, login, logout, getAllWatched, getTotalEpisodes, getAvgRating
    }}>
      {children}
      {toast && <Toast toast={toast}/>}
    </Ctx.Provider>
  );
}

/* ============================================================
   SMALL SHARED COMPONENTS
============================================================ */
function Toast({toast}){
  const icons={success:'✅',info:'ℹ️',error:'❌',warn:'⚠️'};
  const colors={success:'border-emerald-500/50 bg-emerald-900/80',info:'border-blue-500/50 bg-blue-900/80',error:'border-red-500/50 bg-red-900/80',warn:'border-amber-500/50 bg-amber-900/80'};
  return (
    <div className={`fixed bottom-6 right-6 z-[999] animate-slideUp px-5 py-3 rounded-xl border backdrop-blur-xl flex items-center gap-3 shadow-2xl text-white text-sm font-medium max-w-xs ${colors[toast.type]||colors.info}`}>
      <span className="text-lg">{icons[toast.type]||icons.info}</span>
      <span>{toast.message}</span>
    </div>
  );
}

function SkeletonCard(){
  return (
    <div className="rounded-xl overflow-hidden bg-bg-card border border-white/5 w-44 flex-shrink-0">
      <div className="aspect-[2/3] shimmer-bg"/>
      <div className="p-3 space-y-2">
        <div className="h-4 shimmer-bg rounded w-3/4"/>
        <div className="h-3 shimmer-bg rounded w-1/2"/>
      </div>
    </div>
  );
}

function SkeletonGrid({n=12}){
  return (
    <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4">
      {Array(n).fill(0).map((_,i)=>(
        <div key={i} className="rounded-xl overflow-hidden bg-bg-card border border-white/5">
          <div className="aspect-[2/3] shimmer-bg"/>
          <div className="p-3 space-y-2">
            <div className="h-4 shimmer-bg rounded w-3/4"/>
            <div className="h-3 shimmer-bg rounded w-1/2"/>
          </div>
        </div>
      ))}
    </div>
  );
}

function Spinner(){
  return (
    <div className="flex justify-center items-center py-16">
      <div className="w-12 h-12 rounded-full border-4 border-neon-purple/20 border-t-neon-purple animate-spin"/>
    </div>
  );
}

function Stars({rating, max=10, size='sm'}){
  const sz = size==='sm' ? 'text-sm' : 'text-lg';
  return (
    <div className={`flex gap-0.5 ${sz}`}>
      {Array(max).fill(0).map((_,i)=>(
        <span key={i} className={i<Math.round(rating/2)?'star-filled':'star-empty'}>★</span>
      ))}
    </div>
  );
}

function StarRater({value, onChange}){
  const [hover,setHover] = React.useState(0);
  return (
    <div className="flex gap-1 text-xl cursor-pointer">
      {Array(10).fill(0).map((_,i)=>(
        <span key={i}
          className={(i<(hover||value)?'text-anime-gold':'text-white/20')+' hover:scale-125 transition-transform'}
          onMouseEnter={()=>setHover(i+1)}
          onMouseLeave={()=>setHover(0)}
          onClick={()=>onChange(i+1)}
        >★</span>
      ))}
    </div>
  );
}

function ScoreBadge({score}){
  const s = parseFloat(score);
  const color = s>=8.5?'from-amber-400 to-yellow-300':s>=7?'from-emerald-400 to-green-300':s>=5?'from-blue-400 to-cyan-300':'from-gray-500 to-gray-400';
  return (
    <div className={`inline-flex items-center gap-1 px-2 py-0.5 rounded-lg bg-gradient-to-r ${color} text-black font-bold text-xs`}>
      ⭐ {s?s.toFixed(1):'N/A'}
    </div>
  );
}

/* ============================================================
   ANIME CARD
============================================================ */
function AnimeCard({anime, compact=false, onClick}){
  const {getAnimeStatus, addToList, user} = React.useContext(Ctx);
  const [showDrop, setShowDrop] = React.useState(false);
  const [imgLoaded, setImgLoaded] = React.useState(false);
  const status = getAnimeStatus(anime.mal_id);
  const poster = anime.images?.jpg?.large_image_url || anime.images?.jpg?.image_url || '';
  const title = anime.title_english || anime.title;

  const handleAdd = (e, s) => {
    e.stopPropagation();
    addToList(anime, s);
    setShowDrop(false);
  };

  return (
    <div
      className={`relative group card-hover cursor-pointer rounded-xl overflow-hidden bg-bg-card border border-white/5 hover:border-neon-purple/40 flex-shrink-0 ${compact?'w-36':'w-44'}`}
      onClick={()=>{if(onClick)onClick(anime);else navigate(`anime/${anime.mal_id}`)}}
    >
      <div className={`relative overflow-hidden ${compact?'aspect-[2/3]':'aspect-[2/3]'}`}>
        {!imgLoaded && <div className="absolute inset-0 shimmer-bg"/>}
        <img
          src={poster} alt={title}
          loading="lazy"
          onLoad={()=>setImgLoaded(true)}
          className={`w-full h-full object-cover group-hover:scale-105 transition-transform duration-500 ${imgLoaded?'opacity-100':'opacity-0'}`}
        />
        {status && (
          <div className="absolute top-2 left-2">
            <span className={`badge ${STATUS_CONFIG[status]?.color}`}>{STATUS_CONFIG[status]?.icon}</span>
          </div>
        )}
        {anime.score && (
          <div className="absolute top-2 right-2">
            <ScoreBadge score={anime.score}/>
          </div>
        )}
        {/* Hover overlay */}
        <div className="absolute inset-0 bg-gradient-to-t from-black/95 via-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col justify-end p-3 gap-2">
          <div className="text-gray-300 text-xs line-clamp-2">{anime.genres?.slice(0,2).map(g=>g.name).join(' · ')}</div>
          <div className="relative">
            <button
              className="btn-primary w-full py-1.5 rounded-lg text-xs font-semibold"
              onClick={e=>{e.stopPropagation();setShowDrop(d=>!d)}}
            >+ Add to List ▾</button>
            {showDrop && (
              <div className="dropdown absolute bottom-full left-0 right-0 mb-1">
                {Object.keys(STATUS_CONFIG).map(s=>(
                  <div key={s} className={`dropdown-item ${status===s?'text-neon-purple':''}`}
                    onClick={e=>handleAdd(e,s)}>
                    <span>{STATUS_CONFIG[s].icon}</span>
                    <span>{STATUS_CONFIG[s].label}</span>
                  </div>
                ))}
              </div>
            )}
          </div>
        </div>
      </div>
      <div className="p-2.5">
        <div className="text-white text-xs font-semibold leading-tight line-clamp-2 mb-1">{title}</div>
        <div className="text-gray-500 text-xs flex items-center gap-1.5">
          <span>{anime.year||anime.aired?.prop?.from?.year||'?'}</span>
          {!compact && <><span>·</span><span>{anime.type||'TV'}</span></>}
        </div>
      </div>
    </div>
  );
}

/* ============================================================
   ANIME ROW SECTION
============================================================ */
function AnimeRow({title, icon, apiPath, extraLink}){
  const [items, setItems] = React.useState([]);
  const [loading, setLoading] = React.useState(true);

  React.useEffect(()=>{
    let active = true;
    setLoading(true);
    cachedJikan(apiPath).then(d=>{
      if (active && d?.data) setItems(d.data.slice(0,14));
      setLoading(false);
    });
    return ()=>{active=false};
  },[apiPath]);

  return (
    <section className="mb-10">
      <div className="flex items-center justify-between mb-4">
        <h2 className="section-title gradient-text">
          <span>{icon}</span>{title}
        </h2>
        {extraLink && (
          <button onClick={()=>navigate(extraLink)}
            className="text-neon-purple text-sm hover:text-neon-pink transition-colors">
            View all →
          </button>
        )}
      </div>
      <div className="scroll-row">
        <div className="scroll-row-inner">
          {loading
            ? Array(8).fill(0).map((_,i)=><SkeletonCard key={i}/>)
            : items.map(a=><AnimeCard key={a.mal_id} anime={a}/>)
          }
        </div>
      </div>
    </section>
  );
}

/* ============================================================
   NAVBAR
============================================================ */
function Navbar({page}){
  const {user, logout} = React.useContext(Ctx);
  const [searchOpen, setSearchOpen] = React.useState(false);
  const [searchQ, setSearchQ] = React.useState('');
  const [menuOpen, setMenuOpen] = React.useState(false);
  const inputRef = React.useRef(null);

  const doSearch = e => {
    e.preventDefault();
    if (searchQ.trim()) { navigate(`search/${encodeURIComponent(searchQ.trim())}`); setSearchOpen(false); setSearchQ(''); }
  };

  React.useEffect(()=>{ if(searchOpen && inputRef.current) inputRef.current.focus(); },[searchOpen]);

  const navLinks = [
