/* ============================================================
   STATISTICS PAGE
============================================================ */
function StatsPage(){
  const {user, getAllWatched, getTotalEpisodes, getAvgRating} = React.useContext(Ctx);

  if (!user.isLoggedIn) return (
    <div className="pt-24 flex items-center justify-center min-h-[60vh]">
      <div className="text-center">
        <div className="text-5xl mb-4">📊</div>
        <h2 className="text-xl font-bold text-white mb-3">Login to see your statistics</h2>
        <button onClick={()=>navigate('login')} className="btn-primary px-6 py-3 rounded-xl">Login</button>
      </div>
    </div>
  );

  const all = getAllWatched();
  const totalEps = getTotalEpisodes();

  // Genre distribution
  const genreCount = {};
  all.forEach(a=>{ (a.genres||[]).forEach(g=>{ genreCount[g.name]=(genreCount[g.name]||0)+1; }); });
  const topGenres = Object.entries(genreCount).sort((a,b)=>b[1]-a[1]).slice(0,10);
  const maxG = topGenres[0]?.[1]||1;

  // Status distribution
  const statusDist = Object.keys(STATUS_CONFIG).map(s=>({
    label: STATUS_CONFIG[s].label,
    count: (user.watchlist?.[s]||[]).length,
    color: s==='completed'?'#3b82f6':s==='watching'?'#10b981':s==='planToWatch'?'#f59e0b':'#ef4444'
  }));

  // Rating distribution
  const ratingDist = Array(10).fill(0).map((_,i)=>({
    r: i+1,
    count: Object.values(user.ratings||{}).filter(v=>v===i+1).length
  }));
  const maxR = Math.max(...ratingDist.map(r=>r.count), 1);

  // SVG pie chart for genres
  const total = topGenres.reduce((s,[,v])=>s+v,0)||1;
  const genreColors = ['#7c3aed','#ec4899','#3b82f6','#10b981','#f59e0b','#ef4444','#06b6d4','#8b5cf6','#f97316','#84cc16'];

  let pieAngle = 0;
  const pieSlices = topGenres.slice(0,6).map(([name, count], i)=>{
    const pct = count/total;
    const start = pieAngle;
    pieAngle += pct * 360;
    const r=70, cx=80, cy=80;
    const a1 = (start-90)*Math.PI/180, a2=(pieAngle-90)*Math.PI/180;
    const x1=cx+r*Math.cos(a1), y1=cy+r*Math.sin(a1);
    const x2=cx+r*Math.cos(a2), y2=cy+r*Math.sin(a2);
    const large=pct>0.5?1:0;
    return {name, count, pct, path:`M${cx},${cy} L${x1},${y1} A${r},${r} 0 ${large},1 ${x2},${y2} Z`, color:genreColors[i]};
  });

  return (
    <div className="max-w-5xl mx-auto px-4 md:px-8 pt-24 pb-16">
      <div className="mb-8">
        <h1 className="text-4xl font-black gradient-text mb-2">My Statistics</h1>
        <p className="text-gray-500">Your anime journey in numbers</p>
      </div>

      {/* Big Stats */}
      <div className="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
        {[
          {l:'Total Anime', v:all.length, icon:'📺', sub:'all time'},
          {l:'Episodes', v:fmt(totalEps), icon:'🎞️', sub:'watched'},
          {l:'Hours Watched', v:fmt(hrs(totalEps)), icon:'⏱️', sub:`≈${Math.round(hrs(totalEps)/24)} days`},
          {l:'Avg Rating', v:getAvgRating(), icon:'⭐', sub:`${Object.keys(user.ratings||{}).length} rated`},
        ].map(s=>(
          <div key={s.l} className="glass rounded-2xl p-6 text-center card-hover">
            <div className="text-4xl mb-3">{s.icon}</div>
            <div className="text-3xl font-black gradient-text mb-1">{s.v}</div>
            <div className="text-gray-400 text-sm font-medium">{s.l}</div>
            <div className="text-gray-600 text-xs mt-1">{s.sub}</div>
          </div>
        ))}
      </div>

      <div className="grid md:grid-cols-2 gap-8 mb-8">
        {/* Genre Pie Chart */}
        <div className="glass rounded-2xl p-6">
          <h2 className="font-bold text-white mb-5">🎭 Genre Distribution</h2>
          {topGenres.length>0 ? (
            <div className="flex items-center gap-6">
              <svg viewBox="0 0 160 160" className="w-36 h-36 flex-shrink-0">
                {pieSlices.map((s,i)=>(
                  <path key={i} d={s.path} fill={s.color} className="hover:opacity-80 transition-opacity cursor-pointer">
                    <title>{s.name}: {s.count}</title>
                  </path>
                ))}
              </svg>
              <div className="flex-1 space-y-2">
                {pieSlices.map((s,i)=>(
                  <div key={i} className="flex items-center gap-2 text-sm">
                    <div className="w-3 h-3 rounded-full flex-shrink-0" style={{background:s.color}}/>
                    <span className="text-gray-400 flex-1">{s.name}</span>
                    <span className="text-white font-semibold">{s.count}</span>
                  </div>
                ))}
              </div>
            </div>
          ) : <p className="text-gray-500 text-sm py-8 text-center">Add anime to your list to see genre stats</p>}
        </div>

        {/* Status Distribution */}
        <div className="glass rounded-2xl p-6">
          <h2 className="font-bold text-white mb-5">📋 List Status</h2>
          <div className="space-y-4">
            {statusDist.map(s=>(
              <div key={s.label} className="flex items-center gap-3">
                <div className="w-3 h-3 rounded-full flex-shrink-0" style={{background:s.color}}/>
                <span className="text-gray-400 text-sm w-32">{s.label}</span>
                <div className="flex-1 progress-bar">
                  <div className="h-full rounded-full transition-all" style={{width:`${(s.count/Math.max(all.length,1))*100}%`,background:s.color}}/>
                </div>
                <span className="text-white font-bold text-sm w-6 text-right">{s.count}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      {/* Rating Distribution */}
      <div className="glass rounded-2xl p-6 mb-8">
        <h2 className="font-bold text-white mb-5">⭐ Rating Distribution</h2>
        <div className="flex items-end justify-between gap-2 h-32">
          {ratingDist.map(({r,count})=>(
            <div key={r} className="flex-1 flex flex-col items-center gap-1">
              <span className="text-neon-purple text-xs font-bold">{count||''}</span>
              <div className="w-full rounded-t-lg transition-all"
                style={{height:`${count?Math.max(8, count/maxR*96):4}px`, background:count?'linear-gradient(to top,#7c3aed,#ec4899)':'rgba(124,58,237,0.1)'}}/>
              <span className="text-gray-600 text-xs">{r}</span>
            </div>
          ))}
        </div>
        <div className="text-center text-gray-600 text-xs mt-2">Rating (1–10)</div>
      </div>

      {/* Top Genres Bar */}
      {topGenres.length>0 && (
        <div className="glass rounded-2xl p-6">
          <h2 className="font-bold text-white mb-5">🏆 Favorite Genres</h2>
          <div className="space-y-3">
            {topGenres.map(([name,count],i)=>(
              <div key={name} className="flex items-center gap-4">
                <span className="text-gray-500 text-xs w-4 text-right">{i+1}</span>
                <span className="text-gray-300 text-sm w-28">{name}</span>
                <div className="flex-1 progress-bar">
                  <div className="progress-fill" style={{width:`${count/maxG*100}%`}}/>
                </div>
                <span className="text-neon-purple font-bold text-sm w-6 text-right">{count}</span>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}

/* ============================================================
   LOGIN PAGE
============================================================ */
function LoginPage(){
  const {user, login} = React.useContext(Ctx);
  const [mode, setMode] = React.useState('login');
  const [email, setEmail] = React.useState('');
  const [password, setPassword] = React.useState('');
  const [username, setUsername] = React.useState('');
  const [loading, setLoading] = React.useState(false);
  const [error, setError] = React.useState('');

  if (user.isLoggedIn) { navigate('dashboard'); return null; }

  const handleSubmit = e => {
    e.preventDefault();
    setError('');
    if (!email || !password) { setError('Please fill all fields'); return; }
    if (mode==='register' && !username) { setError('Username is required'); return; }
    setLoading(true);
    setTimeout(()=>{
      login({ username: mode==='register' ? username : email.split('@')[0], email });
      setLoading(false);
      navigate('dashboard');
    }, 1000);
  };

  const demoLogin = () => {
    setLoading(true);
    setTimeout(()=>{
      login({username:'AniVaultFan', email:'demo@anivault.com'});
      setLoading(false);
      navigate('dashboard');
    }, 800);
  };

  const googleLogin = () => {
    setLoading(true);
    setTimeout(()=>{
      login({username:'AnimeKing', email:'user@gmail.com'});
      setLoading(false);
      navigate('dashboard');
    }, 1000);
  };

  return (
    <div className="min-h-screen flex items-center justify-center px-4 pt-16 hero-bg">
      <div className="orb w-80 h-80 bg-purple-600 top-20 -left-40"/>
      <div className="orb w-80 h-80 bg-pink-600 bottom-20 -right-40"/>
      <div className="w-full max-w-md relative z-10 animate-slideUp">
        <div className="text-center mb-8">
          <button onClick={()=>navigate('home')} className="text-4xl font-black gradient-text text-3xl">🎌 AniVault</button>
          <p className="text-gray-400 mt-2">Your anime journey starts here</p>
        </div>
        <div className="glass rounded-3xl p-8">
          {/* Tabs */}
          <div className="flex gap-1 mb-8 bg-white/5 rounded-xl p-1">
            {['login','register'].map(m=>(
              <button key={m} onClick={()=>{setMode(m);setError('')}}
                className={`flex-1 py-2.5 rounded-lg text-sm font-semibold transition-all capitalize ${mode===m?'bg-neon-purple text-white':'text-gray-400 hover:text-white'}`}>
                {m==='login'?'Login':'Register'}
              </button>
            ))}
          </div>

          {error && (
            <div className="bg-red-900/30 border border-red-500/30 rounded-xl px-4 py-3 mb-5 text-red-400 text-sm">{error}</div>
          )}

          <form onSubmit={handleSubmit} className="space-y-4">
            {mode==='register' && (
              <div>
                <label className="text-gray-400 text-sm block mb-1.5">Username</label>
                <input value={username} onChange={e=>setUsername(e.target.value)}
                  placeholder="Choose a username"
                  className="input-dark w-full rounded-xl px-4 py-3"/>
              </div>
            )}
            <div>
              <label className="text-gray-400 text-sm block mb-1.5">Email</label>
              <input type="email" value={email} onChange={e=>setEmail(e.target.value)}
                placeholder="your@email.com"
                className="input-dark w-full rounded-xl px-4 py-3"/>
            </div>
            <div>
              <label className="text-gray-400 text-sm block mb-1.5">Password</label>
              <input type="password" value={password} onChange={e=>setPassword(e.target.value)}
                placeholder="••••••••"
                className="input-dark w-full rounded-xl px-4 py-3"/>
            </div>
            <button type="submit" disabled={loading}
              className="btn-primary w-full py-3.5 rounded-xl font-bold text-base disabled:opacity-60 mt-2">
              {loading ? '⏳ Please wait…' : mode==='login'?'Login to AniVault':'Create Account'}
            </button>
          </form>

          <div className="flex items-center gap-3 my-5">
            <div className="flex-1 h-px bg-white/10"/>
            <span className="text-gray-600 text-xs">OR</span>
            <div className="flex-1 h-px bg-white/10"/>
          </div>

          <div className="space-y-3">
            <button onClick={googleLogin} disabled={loading}
              className="btn-secondary w-full py-3 rounded-xl font-semibold flex items-center justify-center gap-3">
              <svg className="w-5 h-5" viewBox="0 0 24 24">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
              Continue with Google
            </button>

            <button onClick={demoLogin} disabled={loading}
              className="w-full py-3 rounded-xl font-semibold bg-neon-cyan/10 border border-neon-cyan/30 text-neon-cyan hover:bg-neon-cyan/20 transition-all flex items-center justify-center gap-2">
              ⚡ Try Demo Account
            </button>
          </div>
        </div>
      </div>
    </div>
  );
}

