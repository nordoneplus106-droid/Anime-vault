/* ============================================================
   MAIN APP ROUTER
============================================================ */
function App(){
  const [page, setPage] = React.useState(hashPage());

  React.useEffect(()=>{
    const handler = () => setPage(hashPage());
    window.addEventListener('hashchange', handler);
    return ()=>window.removeEventListener('hashchange', handler);
  },[]);

  const showNav = page !== 'login';

  const renderPage = () => {
    if (page==='home') return <HomePage/>;
    if (page==='search') return <SearchPage/>;
    if (page.startsWith('search/')) return <SearchPage query={page.slice(7)}/>;
    if (page==='browse') return <BrowsePage/>;
    if (page.startsWith('genre/')) {
      const parts = page.split('/');
      return <GenrePage id={parts[1]} name={parts[2]||'Genre'}/>;
    }
    if (page.startsWith('anime/')) return <AnimePage id={page.split('/')[1]}/>;
    if (page==='dashboard') return <DashboardPage/>;
    if (page==='profile') return <ProfilePage/>;
    if (page==='stats') return <StatsPage/>;
    if (page==='login') return <LoginPage/>;
    return <NotFoundPage/>;
  };

  return (
    <AppProvider>
      {showNav && <Navbar page={page}/>}
      <main style={{minHeight:'100vh'}}>
        {renderPage()}
      </main>
      {/* Footer */}
      {showNav && (
        <footer className="border-t border-white/5 mt-16 py-10 px-8 text-center text-gray-600 text-sm">
          <div className="text-2xl mb-2">🎌</div>
          <div className="font-bold text-gray-400 mb-1">AniVault</div>
          <p>Anime data powered by <a href="https://jikan.moe" target="_blank" className="text-neon-purple hover:text-neon-pink transition-colors">Jikan API</a> (MyAnimeList)</p>
          <p className="mt-1">Built with React + Tailwind CSS + ❤️</p>
        </footer>
      )}
    </AppProvider>
  );
}

ReactDOM.createRoot(document.getElementById('root')).render(<App/>);
</script>
