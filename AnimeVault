============================================================ */
function GenrePage({id, name}){
  const [items, setItems] = React.useState([]);
  const [loading, setLoading] = React.useState(true);
  const [page, setPage] = React.useState(1);
  const [hasMore, setHasMore] = React.useState(false);
  const genre = GENRES.find(g=>g.id===parseInt(id));

  const load = async (pg=1, append=false) => {
    setLoading(true);
    const d = await jikan(`/anime?genres=${id}&order_by=score&sort=desc&limit=24&page=${pg}`);
    if (d?.data) {
      setItems(r => append ? [...r,...d.data] : d.data);
      setHasMore(d.pagination?.has_next_page||false);
    }
    setLoading(false);
  };

  React.useEffect(()=>{ setItems([]); setPage(1); load(1); },[id]);

  return (
    <div className="max-w-[1400px] mx-auto px-4 md:px-8 pt-24 pb-16">
      <div className={`relative overflow-hidden rounded-3xl p-8 md:p-12 mb-10 bg-gradient-to-br ${genre?.color||'from-neon-purple to-neon-pink'}`}>
        <div className="orb w-80 h-80 bg-black/40 -right-20 -top-20"/>
        <div className="relative z-10">
          <div className="text-5xl md:text-7xl mb-3">{genre?.icon||'🎭'}</div>
          <h1 className="text-3xl md:text-5xl font-black text-white mb-2">{decodeURIComponent(name)}</h1>
          <p className="text-white/70 text-lg">Top rated {decodeURIComponent(name).toLowerCase()} anime</p>
        </div>
      </div>

      {loading && items.length===0 ? <SkeletonGrid n={24}/> : (
        <>
          <div className="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-4 mb-8">
            {items.map(a=>(
              <div key={a.mal_id} className="flex justify-center">
                <AnimeCard anime={a}/>
              </div>
            ))}
          </div>
          {hasMore && (
            <div className="text-center">
              <button onClick={()=>{const np=page+1;setPage(np);load(np,true)}} disabled={loading}
                className="btn-primary px-8 py-3 rounded-xl font-semibold">
                Load More
              </button>
            </div>
          )}
        </>
      )}
    </div>
  );
}

